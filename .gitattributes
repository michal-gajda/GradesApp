# Normalize text files in repository
* text=auto

# Source files
*.c text
*.cc text
*.cpp text
*.h text
*.hpp text
*.cmake text
CMakeLists.txt text

# Scripts
*.ps1 text eol=crlf
*.sh text eol=lf

# Project and config files
*.md text
*.yml text
*.yaml text
*.json text
*.ui text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.pdb binary